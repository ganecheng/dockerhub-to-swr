ARG BASE_IMAGE
FROM ${BASE_IMAGE}

COPY gitea-runner-ubuntu/modules/common.sh gitea-runner-ubuntu/modules/graalvm-jdk21.sh gitea-runner-ubuntu/modules/settings.xml /tmp/
RUN bash /tmp/graalvm-jdk21.sh && rm -f /tmp/*.sh /tmp/settings.xml

ENV JAVA_HOME=/opt/graalvm-jdk-21 \
    MAVEN_HOME=/opt/maven \
    PATH="/opt/graalvm-jdk-21/bin:/opt/maven/bin:${PATH}" \
    GITEA_RUNNER_LABELS_DEFAULT='ubuntu-latest,ubuntu-26.04,ubuntu-graalvm-jdk-21'
